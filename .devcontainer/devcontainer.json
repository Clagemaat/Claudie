{
  "name": "Claudie Workflow Backend",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace/backend",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI (Swagger UI at /docs)",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && alembic upgrade head",
  "postStartCommand": "bash -c 'nohup uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload > /tmp/uvicorn.log 2>&1 &'",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
